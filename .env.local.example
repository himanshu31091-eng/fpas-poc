# Copy this file to `.env.local` and fill in your key to enable real Claude calls.
# If ANTHROPIC_API_KEY is left blank, the app runs in MOCK mode:
# every AI screen still works using deterministic canned responses,
# so you can demo the full flow offline.

ANTHROPIC_API_KEY=

# Model used for extraction, readiness reasoning, and artifact drafting.
# Override if your key has access to a different model.
ANTHROPIC_MODEL=claude-sonnet-5
